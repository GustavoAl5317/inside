# Banco (Neon ou Postgres)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# URL pública do app na VM (usada em callbacks Omie)
NEXT_PUBLIC_APP_URL=http://10.172.101.25:3000

# Bitrix
BITRIX_LIST_FAMILY_ID=65
BITRIX_LIST_PAYMENT_ID=67

# Omie — Barueri (filial 1)
OMIE_APP_KEY_1=
OMIE_APP_SECRET_1=

# Omie — ES (filial 2)
OMIE_APP_KEY_2=
OMIE_APP_SECRET_2=

OMIE_SLEEP_MS=260

# Produção
NODE_ENV=production
APP_SESSION_SECRET=troque-por-uma-chave-longa-e-aleatoria
